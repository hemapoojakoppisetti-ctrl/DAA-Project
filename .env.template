# ============================================
# DAA — Dynamic Academic Audits
# Environment Configuration Template
# ============================================

# ---- BACKEND (server/.env) ----

# PostgreSQL Connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/daa_db"

# JWT Secret — change this to a strong random string in production
JWT_SECRET="daa_super_secret_key_2024_jntuk_change_in_production"

# Server Port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:3000"

# Environment
NODE_ENV="development"


# ---- FRONTEND (client/.env) ----

# API Base URL — only needed if backend is on a different domain
# For local dev with proxy in package.json, leave this empty
REACT_APP_API_URL=

# For production:
# REACT_APP_API_URL=https://your-backend.railway.app/api


